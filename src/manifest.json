{
  "manifest_version": 3,
  "name": "SenseUI",
  "version": "0.1.0",
  "description": "AI-powered visual design feedback for blind and visually impaired developers",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SenseUI"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open SenseUI"
    }
  }
}